<h1>Projects</h1>

<% if current_user.manager? %>
  <%= link_to "Add New Project", new_project_path, class: "btn btn-add" %>
<% end %>

<!-- ===== Ransack Search Form ===== -->
<%= search_form_for @q, url: projects_path, method: :get, html: { class: "search-fields", style: "margin: 20px 0; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;" } do |f| %>
  <div style="flex: 1; min-width: 200px;">
    <%= f.label :title_cont, "Title contains", class: "search-label" %>
    <%= f.search_field :title_cont, placeholder: "Search by project title...", class: "search-input" %>
  </div>

  <div style="flex: 1; min-width: 200px;">
    <%= f.label :description_cont, "Description contains", class: "search-label" %>
    <%= f.search_field :description_cont, placeholder: "Search by description...", class: "search-input" %>
  </div>

  <div style="display: flex; gap: 5px; align-items: flex-end;">
    <%= f.submit "Search", class: "btn btn-primary", style: "background-color: #007bff; color: white; font-weight: bold; padding: 8px 16px; border-radius: 5px;" %>
    <%= link_to "Clear", projects_path, class: "btn btn-secondary", style: "background-color: #6c757d; color: white; font-weight: bold; padding: 8px 16px; border-radius: 5px;" %>
  </div>
<% end %>

<!-- ===== Projects Table ===== -->
<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Description</th>
      <th>Assigned Users</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @projects.each do |project| %>
      <tr>
        <td><%= project.title %></td>
        <td><%= project.description %></td>
        <td><%= project.users.map(&:email).join(", ") %></td>
        <td>
          <%= link_to "View", project_path(project), class: "btn btn-view" %>

          <% if current_user.manager? %>
            <%= link_to "Edit", edit_project_path(project), class: "btn btn-edit" %>
            <%= button_to "Delete", project_path(project),
              method: :delete,
              data: { confirm: "Are you sure?" },
              class: "btn btn-delete" %>
            <%= link_to "Assign Users", assign_users_project_path(project),
                        class: "btn btn-assign" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>