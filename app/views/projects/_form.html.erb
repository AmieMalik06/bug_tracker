<div class="form-container">

<h2><%= @project.new_record? ? "New Project" : "Edit Project" %></h2>

<%= form_with(model: @project, local: true) do |form| %>

  <% if @project.errors.any? %>
    <div class="error-box">
      <h4><%= pluralize(@project.errors.count, "error") %> prevented saving:</h4>
      <ul>
        <% @project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title %>
    <%= form.text_field :title, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :description %>
    <%= form.text_area :description, class: "form-input" %>
  </div>

  <% if current_user.manager? %>
    <div class="form-group">
      <%= form.label :user_ids, "Assign Users" %>
      <%= form.collection_select :user_ids,
            User.where(role: [:developer, :qa]),
            :id,
            :email,
            {},
            { multiple: true, class: "form-input" } %>
    </div>
  <% end %>

  <div class="form-actions">
    <%= form.submit class: "submit-btn" %>
  </div>

<% end %>

</div>