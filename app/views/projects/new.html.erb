<div class="form-container">
  <h1><%= @project.new_record? ? "New Project" : "Edit Project" %></h1>

  <%= form_with model: @project, local: true do |f| %>

    <div class="form-group">
      <%= f.label :title %>
      <%= f.text_field :title, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :description %>
      <%= f.text_area :description, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label "Assign Users" %>
      <%= f.collection_select :user_ids,
            User.where(role: [:qa, :developer]),
            :id, :email,
            {},
            { multiple: true, class: "form-input" } %>
    </div>

    <div class="form-actions">
      <%= f.submit @project.new_record? ? "Create Project" : "Update Project", class: "submit-btn" %>
    </div>

  <% end %>
</div>