<h1 style="text-align:center; margin-bottom:20px;"><%= @bug.new_record? ? "New Bug" : "Edit Bug" %></h1>

<%= form_with(model: [@project, @bug], local: true, html: { multipart: true, class: "bug-form" }) do |f| %>

  <% if flash[:alert].present? %>
    <div class="alert alert-danger"><%= flash[:alert] %></div>
  <% end %>

  <% if @bug.errors.any? %>
    <div class="alert alert-danger">
      <h4>There were some errors:</h4>
      <ul>
        <% @bug.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title, class: "form-control", placeholder: "Enter bug title" %>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Describe the bug" %>
  </div>

  <div class="form-row">
    <div class="form-group" style="flex:1;">
      <%= f.label :bug_type, "Type" %>
      <%= f.select :bug_type, Bug.bug_types.keys.map { |t| [t.titleize, t] }, {}, { id: "bug_type_select", class: "form-control" } %>
    </div>
    <div class="form-group" style="flex:1;">
      <%= f.label :status %>
      <%= f.select :status, @bug.available_statuses.map { |name, value| [name, value] }, {}, { id: "status_select", class: "form-control" } %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :screenshot %>
    <%= f.file_field :screenshot, accept: "image/png,image/gif", class: "form-control-file" %>
    <small class="form-text text-muted">Allowed formats: PNG, GIF</small>
  </div>

  <div class="form-actions" style="text-align:center;">
    <%= f.submit @bug.new_record? ? "Create Bug" : "Update Bug", class: "btn btn-primary btn-lg" %>
  </div>

<% end %>

<script>
document.addEventListener("turbo:load", () => {
  const typeSelect = document.getElementById("bug_type_select");
  const statusSelect = document.getElementById("status_select");
  if (!typeSelect || !statusSelect) return;

  const statusOptions = {
    feature: [
      { name: "New", value: "new_feature" },
      { name: "Started", value: "started" },
      { name: "Completed", value: "completed" }
    ],
    bug: [
      { name: "New", value: "new_bug" },
      { name: "Started", value: "started" },
      { name: "Resolved", value: "resolved" }
    ]
  };

  function updateStatus() {
    const selectedType = typeSelect.value;
    statusSelect.innerHTML = "";
    statusOptions[selectedType].forEach(opt => {
      const option = document.createElement("option");
      option.value = opt.value;
      option.text = opt.name;
      statusSelect.appendChild(option);
    });
  }

  typeSelect.addEventListener("change", updateStatus);
  updateStatus();
});
</script>