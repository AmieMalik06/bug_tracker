<h1>Welcome, <%= current_user.email %> (<%= current_user.role.titleize %>)</h1>

<% if current_user.manager? %>
  <h3>Total Projects: <%= @projects.count %></h3>
  <h3>Total Pending Bugs: <%= @pending_bugs.count %></h3>
<% end %>

<h2>Projects</h2>

<table border="1" cellpadding="5" cellspacing="0">
  <thead>
    <tr>
      <th>Title</th>
      <th>Description</th>
      <th>Assigned Users (Role)</th>
      <th>Actions</th>
      <% if current_user.manager? %>
        <th>Pending Bugs</th>
      <% end %>
    </tr>
  </thead>

  <tbody>
    <% @projects.each do |project| %>
      <tr>
        <td><%= project.title %></td>
        <td><%= project.description %></td>

        <td>
          <% project.users.each do |user| %>
            <%= user.email %> (<%= user.role.titleize %>)<br>
          <% end %>
        </td>

        <td>
          <%= link_to "View", project_path(project) %>
        </td>

        <% if current_user.manager? %>
          <td>
            <%= project.bugs.where.not(status: [:completed, :resolved]).count %>
          </td>
        <% end %>

      </tr>
    <% end %>
  </tbody>
</table>

<% if current_user.manager? %>

<h2>Pending Bugs</h2>

<table border="1" cellpadding="5" cellspacing="0">
  <thead>
    <tr>
      <th>Title</th>
      <th>Type</th>
      <th>Status</th>
      <th>Project</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @pending_bugs.each do |bug| %>
      <tr>
        <td><%= bug.title %></td>
        <td><%= bug.bug_type.titleize %></td>
        <td><%= bug.status.titleize %></td>
        <td><%= bug.project.title %></td>
        <td>
          <%= link_to "View", project_bug_path(bug.project, bug) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% end %>