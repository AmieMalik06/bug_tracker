<!DOCTYPE html>
<html>
<head>
  <title>Bug Tracker</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%# <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %> 
  <%= javascript_importmap_tags %>
  
</head>

<body>

<nav class="navbar">
  <div class="nav-container">
    <h2 class="logo">Bug Tracker</h2>

    <ul class="nav-links">
      <!-- Dashboard (visible if logged in) -->
      <% if current_user %>
        <li class="<%= 'active' if current_page?(dashboard_path) %>">
          <%= link_to "Dashboard", dashboard_path %>
        </li>
      <% end %>

      <!-- Projects (visible if logged in) -->
      <% if current_user %>
        <li class="<%= 'active' if current_page?(projects_path) %>">
          <%= link_to "Projects", projects_path %>
        </li>
      <% end %>
<!-- Project-specific Bugs (only if inside a project and logged in) -->
<% if current_user && @project&.persisted? %>
  <li class="<%= 'active' if current_page?(project_bugs_path(@project)) %>">
    <%= link_to "Bugs", project_bugs_path(@project) %>
  </li>
<% end %>

      <!-- Global Bugs Dashboard (for managers/developers only) -->
      <% if current_user && (current_user.manager? || current_user.developer?) %>
        <li class="<%= 'active' if current_page?(all_bugs_path) %>">
          <%= link_to "All Bugs", all_bugs_path %>
        </li>
      <% end %>


<!-- Navbar notifications for Activity Notification (developers only) -->
<% if current_user&.developer? %>
  <% unread_count = current_user.unread_notifications.count %>
  <li class="notification-menu">
    <%= link_to '#', class: 'dropdown-toggle', id: 'notificationDropdown', data: { bs_toggle: "dropdown" } do %>
      Notifications
      <% if unread_count > 0 %>
        <span class="badge"><%= unread_count %></span>
      <% end %>
    <% end %>

    <ul class="dropdown-menu" aria-labelledby="notificationDropdown">
      <% notifications = current_user.notifications.order(created_at: :desc).limit(10) %>
      <% if notifications.any? %>
        <% notifications.each do |notification| %>
          <li class="<%= 'unread' if notification.read_at.nil? %>">
            <% if notification.target.is_a?(Bug) %>
              <%= link_to notification.target.title, project_bug_path(notification.target.project, notification.target) %>
              <small class="text-muted"><%= time_ago_in_words(notification.created_at) %> ago</small>
            <% else %>
              <span><%= notification.key.humanize %></span>
            <% end %>
          </li>
        <% end %>
      <% else %>
        <li><span class="text-muted">No notifications</span></li>
      <% end %>
    </ul>
  </li>
<% end %>

      <!-- Logout (visible if logged in) -->
      <% if current_user %>
        <li>
          <%= button_to "Logout",
              destroy_user_session_path,
              method: :delete,
              class: "logout-btn",
              data: { turbo_confirm: "Are you sure?" } %>
        </li>
      <% end %>
    </ul>
  </div>
</nav>

<div class="container">
  <%= yield %>
</div>

</body>
</html>